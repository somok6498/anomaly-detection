      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "sum(rate(client_transaction_type_count_total{txn_type=\"$txn_type\"}[1m])) * (sum(rate(client_transaction_type_count_total{txn_type=\"$txn_type\"}[1m])) <= bool (1.5 * avg_over_time(sum(rate(client_transaction_type_count_total{txn_type=\"$txn_type\"}[1m]))[30m:1m]))) + 1.5 * avg_over_time(sum(rate(client_transaction_type_count_total{txn_type=\"$txn_type\"}[1m]))[30m:1m]) * (sum(rate(client_transaction_type_count_total{txn_type=\"$txn_type\"}[1m])) > bool (1.5 * avg_over_time(sum(rate(client_transaction_type_count_total{txn_type=\"$txn_type\"}[1m]))[30m:1m])))",
          "legendFormat": "Normal",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "(sum(rate(client_transaction_type_count_total{txn_type=\"$txn_type\"}[1m])) - 1.5 * avg_over_time(sum(rate(client_transaction_type_count_total{txn_type=\"$txn_type\"}[1m]))[30m:1m])) * (sum(rate(client_transaction_type_count_total{txn_type=\"$txn_type\"}[1m])) > bool (1.5 * avg_over_time(sum(rate(client_transaction_type_count_total{txn_type=\"$txn_type\"}[1m]))[30m:1m])))",
          "legendFormat": "Excess",
          "refId": "B"
        }
